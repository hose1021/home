# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mmcm

# Application
PLATFORM_NAME=MMMC Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public self-registration is intentionally disabled by default.
ALLOW_PUBLIC_REGISTRATION=false

# Storage (Cloudflare R2)
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mmcm-storage

# Finance
MONTHLY_TARIFF_PER_SQM=0.40
BILLING_START_DATE=2025-01

# Optional seed overrides
SEED_TENANT_SLUG=demo
SEED_TENANT_NAME=Demo Residence
SEED_ADMIN_USERNAME=admin.admin
SEED_ADMIN_PASSWORD=change-me-before-production
SEED_OWNER_PASSWORD=change-me-before-production

ADMIN=mikail.huseynov
